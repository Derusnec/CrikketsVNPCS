Vertexlitgeneric
{
	$basetexture "models\WormOnlooker\belly\purrslime\belly_purrslime"
	"$bumpmap"				 "models\WormOnLooker\belly\purrslime\purrslime_normal"
	
	"$phong" "1"
	"$phongexponent" "65" 					 // (controla o espalhamento, maior=menos espalhamento, metal polido ou algo assim)
	"$phongboost" "1" 					 // controle de reflexo/quanto mais alto = mais molhado/reflexo
	"$phongfresnelranges" "[1 1 1]" 	 // força do phong, maior os numeros = phong mais branco e intenso

	"$rimlight" "1"
	"$rimlightexponent" "5"     // não sei, não funciona
	"$rimlightboost" "0.5"        // igual o phongexponent, controla o espalhamento
	"$rimmask" "1"				// Usa o alpha channel do phongexponenttexture como specular (inutil se usar dxt1 sem alpha)

	"$nodecal"					"1"
	"$alphatest"				"1"
	"$allowAlphaToCoverage"		"1"
	"$nocull"					"1"
}