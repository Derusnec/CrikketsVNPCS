VertexLitGeneric
{
	$basetexture "models/fds/dvascrag/tile1c"
	$bumpmap "models/fds/dvascrag/tile1n"
	


	
	"$halflambert" 	"1"
	"$nocull" "1"

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 0.34
	$envmaplightscale 1
	$envmaplightscaleminmax "[0 1]"
	$envmapanisotropy 1
	$envmapanisotropyscale 0.05

	$phong 1
	$phongexponenttexture "models/fds/dvascrag/tile1p"
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost 3


	"$emissiveblendenabled" 	        "1"					// Enable EmissiveBlend. Like $selfillum 1	
    "$emissiveblendstrength" 		"1"				// how strong the entire glow effect is.
    "$emissiveblendtexture" 		"models/fds/dvascrag/null"	// This is the glowing texture's mask, like $selfillummask.  SHOULD BE VTF i8 FORMAT, NOT DXT5!!!
    "$emissiveblendbasetexture" 	"models/fds/dvascrag/emissiveface"	// this is the glowing texture.vtf
    "$emissiveblendflowtexture" 	"models/fds/dvascrag/null"	 		// EmmisiveBlend can "flow" or move. But ours is static, so a white texture is used.
    "$emissiveblendtint" 			" [ .898 .173 .533 ] "		// RGB glow intensity. Leave at 1 1 1. This can be used to change how strong each color should glow.


}
}