VertexLitGeneric
{
	$basetexture "models/fds/dvascrag/stickersc"
	$bumpmap "models/fds/dvascrag/normal"
	
	$alphatest 1
	$allowalphatocoverage 1
	
	
	
	


	
	"$halflambert" 	"1"
	"$nocull" "1"

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 0.34
	$envmaplightscale 1
	$envmaplightscaleminmax "[0 1]"
	$envmapanisotropy 1
	$envmapanisotropyscale 0.05
	
	$phong 1
	$phongexponenttexture "models/fds/dvascrag/white"
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost 1


}