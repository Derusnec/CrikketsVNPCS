"VertexLitGeneric"
{
	"$basetexture" "models/ankha/ankhapm/hairn"
	$bumpmap "models/ankha/ankhapm/normal"
	
	
	

	
	$alphatest 1
	$allowalphatocoverage	1
	
	


	"$halflambert" 	"1"
	"$nocull" "1"

	$phong 1
	$phongexponenttexture "models/ankha/ankhapm/whitec"
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost .25
	
	

	
	

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "4"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "2"		

	
	

	"$blendtintbybasealpha" "0" 
	"$blendtintcoloroverbase" "1"  
	
	
	
}