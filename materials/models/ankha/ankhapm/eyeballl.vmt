"EyeRefract"
{
	"$Iris"               "models/ankha/ankhapm/eyec"			  // Iris color in RGB with cornea noise in A
	"$Iris"               "models/ankha/ankhapm/eyecolorteste"			  // Iris color in RGB with cornea noise in A
	"$AmbientOcclTexture" "models/ankha/ankhapm/eye-extra"				  // Ambient occlusion in RGB, A unused
	"$Envmap"             "models/ankha/ankhapm/eye-reflection-cubemap-"    // Reflection environment map
	"$CorneaTexture"      "models/ankha/ankhapm/eye-cornea"                  // Special texture that has 2D cornea normal in RG and other data in BA
	//"$lightwarptexture" "models/player/pyro/pyro_lightwarp" // This enables TF NPR lighting

	"$EyeballRadius" "0"				// Default 0.5
	"$AmbientOcclColor" "[0.3 0.3 0.3]"	// Default 0.33, 0.33, 0.33
	"$Dilation" "0"					// Default 0.5
	"$ParallaxStrength" "0"          // Default 0.25
	"$CorneaBumpStrength" "0"			// Default 1.0

	"$halflambert" "1"
	"$nodecal" "1"

	// These effects are only available in ps.2.0b and later
	"$RaytraceSphere" "0"				// Default 1 - Enables raytracing in the pixel shader to make the eyeball look round
	"$SphereTexkillCombo" "0"			// Default 1 - Enables killing pixels that don't ray-intersect the sphere


