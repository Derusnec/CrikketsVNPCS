VertexLitGeneric
{
	$basetexture "models/ankha/ankhapm/tile4color.vtf"
	$bumpmap "models/ankha/ankhapm/tile4normal.vtf"
	
	"$halflambert" 	"1"
	"$nocull" "1"
	


	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 0.34
	$envmaplightscale 1
	$envmaplightscaleminmax "[0 1]"
	$envmapanisotropy 1
	$envmapanisotropyscale 0.05

	$phong 1
	$phongexponenttexture "models/ankha/ankhapm/tile4phong.vtf"
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost 8

	//$ambientoccltexture "[your ambient occlusion here]"
	//$ambientocclusion 1
}