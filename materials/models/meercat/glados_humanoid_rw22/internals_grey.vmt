VertexLitGeneric
{
	$basetexture		"models/meercat/glados_humanoid_rw22/vtf/internals_grey" 	// Основная текстура материала
//	$nocull			"1" 						// Игнорировать сглаживание; материал будет отображаться с обеих сторон

	"$bumpmap"		"models/meercat/glados_humanoid_rw22/vtf/internals_grey_ha" 					// Бамп-карта, указывающая на рельеф (здесь используется заглушка)
	"normalmapalphaenvmapmask" "1"
	"$halflambert"		"1" 						// Включает полутеневой эффект для более мягкого освещения

	"$phong"			"1" 						// Включает использование шейдера Phong для блеска
	"$phongboost"		"5"						// Увеличивает интенсивность блеска
	"$phongalbedotint"		"1"						// Применяет окраску альбедо к блеску
	"$phongexponenttexture"	"general_texture/pbr/pbr_g" 				// Текстура для управления блеском (экспонента)
	"$phongfresnelranges"	"[2 .2 .2]" 					// Определяет преломления света в зависимости от угла падения для отражения при различных углах

	"$rimlight"		"1" 						// Включает эффект ободкового света (rim lighting)
	"$rimlightexponent"		"3" 						// Указывает, насколько резким будет ободковый свет
	"$rimlightboost"		"10" 						// Увеличивает интенсивность ободкового света


}
