VertexLitGeneric
{
	$basetexture		"models/meercat/glados_humanoid_rw22/vtf/wires" 	// Основная текстура материала
	"$halflambert"		"1" 						// Включает полутеневой эффект для более мягкого освещения

	"$phong"			"1" 						// Включает использование шейдера Phong для блеска
	"$phongboost"		"1"						// Увеличивает интенсивность блеска
	"$phongalbedotint"		"1"						// Применяет окраску альбедо к блеску
	"$phongexponenttexture"	"general_texture/pbr/pbr_b" 				// Текстура для управления блеском (экспонента)
	"$phongfresnelranges"	"[0 0 10000]" 						// Определяет преломления света в зависимости от угла падения для отражения при различных углах

	"$rimlight"		"1" 						// Включает эффект ободкового света (rim lighting)
	"$rimlightexponent"		"1" 						// Указывает, насколько резким будет ободковый свет
	"$rimlightboost"		"-10" 						// Увеличивает интенсивность ободкового света

	$lightwarptexture "models/meercat/glados_humanoid_rw22/vtf/warp1"


}
