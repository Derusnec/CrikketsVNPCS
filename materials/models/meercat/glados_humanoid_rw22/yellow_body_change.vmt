VertexLitGeneric
{
	$basetexture		 "models/meercat/glados_humanoid_rw22/vtf/yellow_body"	// Основная текстура материала
//	$nocull			"1" 						// Игнорировать сглаживание; материал будет отображаться с обеих сторон

	"$bumpmap"		"null-bumpmap" 					// Бамп-карта, указывающая на рельеф (здесь используется заглушка)
	"$halflambert"		"1" 						// Включает полутеневой эффект для более мягкого освещения
	"$phong"			"1" 						// Включает использование шейдера Phong для блеска
	"$phongboost"		"1"						// Увеличивает интенсивность блеска
	"$phongalbedotint"		"1"						// Применяет окраску альбедо к блеску
	"$phongexponenttexture"	"general_texture/pbr/pbr_g" 				// Текстура для управления блеском (экспонента)
	"$phongfresnelranges"	"[2 .2 .2]" 					// Определяет преломления света в зависимости от угла падения для отражения при различных углах

	"$rimlight"		"1" 						// Включает эффект ободкового света (rim lighting)
	"$rimlightexponent"		"2" 						// Указывает, насколько резким будет ободковый свет
	"$rimlightboost"		"5" 						// Увеличивает интенсивность ободкового света


	"$emissiveblendenabled"	"1" 						// Включает эффект эмиссии (светящийся эффект)
	"$emissiveblendstrength"	"10" 						// Указывает силу эффекта эмиссии
	"$emissiveblendtexture"	"general_texture/null"				 // Текстура для эмиссии (здесь используется заглушка)
	"$emissiveblendbasetexture"	"models/meercat/glados_humanoid_rw22/vtf/yellow_body" 	// Основная текстура для эмиссионного эффекта
	"$emissiveblendflowtexture"	"general_texture/null" 				// Текстура для эффекта потока (здесь используется заглушка)
	"$emissiveblendtint"	"[1 0.6 0.0]" 					// Цветовая окраска эмиссионного эффекта

		Proxies
	{
		PlayerColor
		{
			resultVar	$color2
			default		0.2 0.4 0.7
		}
		Clamp
		{
			min 0.01
			max 1.50
			srcVar1 "$color2"
			resultVar "$color2"
		}
		Clamp
		{
			min 0
			max 1
			srcVar1 "$color2"
			resultVar "$emissiveblendtint"
		}
	}

}



