"VertexLitGeneric"
{
	"$basetexture" "models\alvaroports\Valkyr\Body"
	"$bumpmap" "models\alvaroports\Valkyr\Body_normal"
	"$phongexponenttexture" "models\alvaroports\Valkyr\Body_roughness"
	
	"$phong" "1"
	"$phongexponentfactor" "30"
	"$phongboost" "1" 					 // controle de reflexo/quanto mais alto = mais molhado/reflexo
	"$phongfresnelranges" "[1 1 1]" 	 // força do phong, maior os numeros = phong mais branco e intenso

	"$rimlight" "1"
	"$rimlightexponent" "1"     // não sei, não funciona
	"$rimlightboost" "1"        // igual o phongexponent, controla o espalhamento
	"$rimmask" "1"				// Usa o alpha channel do phongexponenttexture como specular (inutil se usar dxt1 sem alpha)

	"$nodecal"					"1"
	"$nocull"					"1"
	"$emissiveBlendEnabled"			"1"
	"$emissiveBlendFlowTexture"		"vgui/white" //não mexer
	"$emissiveBlendTexture"			"vgui/white" //não mexer
	"$emissiveBlendBaseTexture"		"models\alvaroports\Valkyr\Body_emissive" //local do specular (usar textura com cor, não branco)
	"$emissiveBlendTint" 			"[1 1 1]" //não mexer, eu acho
	"$emissiveBlendStrength" 		"1" // (deixar 1, acima de 1 não tem motivo, eu acho)
	"$emissiveBlendScrollVector"	"[0.0 0.0]" 
}