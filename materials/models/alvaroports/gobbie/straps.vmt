"VertexLitGeneric"
{
	"$basetexture" "models\alvaroports\shared\Leather"
	"$bumpmap" "models\alvaroports\shared\Leather_Normal"
	"$phongexponenttexture" "models\alvaroports\shared\Leather_Roughness"

	"$phong" "1"
	"$phongexponentfactor" "30"
//	"$phongexponent" "6" 					 // (controla o espalhamento, maior=menos espalhamento, metal polido ou algo assim)
	"$phongboost" "1" 					 // controle de reflexo/quanto mais alto = mais molhado/reflexo
//	"$phongtint" "[.8 .8 .8]" 				 // controla a luz (.8 .8 .8 luz menor e mais natural )
	"$phongfresnelranges" "[1 1 1]" 	 // força do phong, maior os numeros = phong mais branco e intenso
//	"$phongalbedotint" "1" 					 // aplicar phong a textura base, desativar se quiser o phong mais branco

	"$nodecal"					"1"
//	"$alphatest"				"1"
//	"$allowAlphaToCoverage"		"1"
	"$nocull"					"1"
	"$color2" "[.7 .7 .7]"
	$nodecal							"1"
//	$alphatest							"1"
//	$allowAlphaToCoverage				"1"
	$nocull								"1"
}
