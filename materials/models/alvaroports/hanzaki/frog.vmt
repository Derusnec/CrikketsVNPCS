"VertexLitGeneric"
{
	"$basetexture" "models\alvaroports\Hanzaki\Frog"
	"$bumpmap" "models\alvaroports\Hanzaki\Frog_normal"
	"$phongexponenttexture" "models\alvaroports\Hanzaki\Frog_roughness"

	"$phong" "1"
	"$phongexponentfactor" "30"
//	"$phongexponent" "10" 					 // (controla o espalhamento, maior=menos espalhamento, metal polido ou algo assim)
	"$phongboost" "1" 					 // controle de reflexo/quanto mais alto = mais molhado/reflexo
	"$phongfresnelranges" "[1 1 1]" 	 // força do phong, maior os numeros = phong mais branco e intenso
//	"$phongfresnelranges" "[0.1 0.5 1]" 	 // força do phong, maior os numeros = phong mais branco e intenso
//	"$phongalbedotint" "1" 					 // aplicar phong a textura base, desativar se quiser o phong mais branco

	"$rimlight" "1"
	"$rimlightexponent" "1"     // não sei, não funciona
	"$rimlightboost" "1"        // igual o phongexponent, controla o espalhamento
	"$rimmask" "1"				// Usa o alpha channel do phongexponenttexture como specular (inutil se usar dxt1 sem alpha)

	"$nodecal"					"1"
	"$alphatest"				"1"
	"$allowAlphaToCoverage"		"1"
	"$nocull"					"1"
//	"$blendtintbybasealpha" "1" // aplica color2 apenas no alpha da textura base
	"$emissiveBlendEnabled"			"1"
	"$emissiveBlendFlowTexture"		"vgui/white" //não mexer
	"$emissiveBlendTexture"			"vgui/white" //não mexer
	"$emissiveBlendBaseTexture"		"models\alvaroports\Hanzaki\Frog_emissive" //local do specular (usar textura com cor, não branco)
	"$emissiveBlendTint" 			"[1 1 1]" //não mexer, eu acho
	"$emissiveBlendStrength" 		"1" // (deixar 1, acima de 1 não tem motivo, eu acho)
	"$emissiveBlendScrollVector"	"[0.0 0.0]" 
}