Vertexlitgeneric
{
	$basetexture "models\WormOnlooker\belly\belly_white.vtf"
	$bumpmap "models\WormOnlooker\belly\dva\dva_normal"
	$phongexponenttexture "models\WormOnlooker\belly\dva\dva_phong"
	
	
	"$color2"	"{200 200 200}"
	


	
	"$halflambert" 	"1"
	"$nocull" "1"

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.70 0.70 0.70]"
	$envmapfresnel 0.34
	$envmaplightscale 1
	$envmaplightscaleminmax "[0 1]"
	$envmapanisotropy 1
	$envmapanisotropyscale 0.05

	$phong 1
	$phongfresnelranges "[0.06 0.41 3]"
	$phongboost 1

}