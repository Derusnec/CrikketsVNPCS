"EyeRefract"
{
	"$Iris" "models/ltusamodels_inc/queen_bom39/eye_"
	"$AmbientOcclTexture" "models/ltusamodels_inc/queen_bom39/Chry_EyeS"
	"$Envmap" "models/ltusamodels_inc/queen_bom39/eye-reflection-cubemap" 
	"$CorneaTexture" "models/ltusamodels_inc/queen_bom39/eye-cornea"

	//"$Envmap" "env_cubemap"
	
	//"$lightwarptexture" "models/player/pyro/pyro_lightwarp"
	//This enables TF NPR lighting

	"$EyeballRadius" "1.25"
	//Default 0.5

	"$AmbientOcclColor" "[0.3 0.3 0.3]"
	//Default 0.33, 0.33, 0.33

	"$Dilation" ".75"
	//Default 0.5

	"$ParallaxStrength" ".25"
	//Default 0.25

	"$CorneaBumpStrength" ".5"
	//Default 1.0

	"$halflambert" "1"
	"$nodecal" "1"

	//These effects are only available in ps.2.0b and later

	"$RaytraceSphere" "0"
	//Enables raytracing in the pixel shader to make the eyeball look round (Gmod = 0, L4D2 = 1)

	"$SphereTexkillCombo" "0"
	//Default 1 - Enables killing pixels that don't ray-intersect the sphere
}

